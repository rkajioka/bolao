# =============================================================================
# Bolão Copa do Mundo — variáveis de ambiente
#
# DESENVOLVIMENTO LOCAL:
#   Copie este arquivo para .env e preencha os campos.
#   Os campos marcados com [SECRET] devem ir para o AWS Secrets Manager
#   em produção e podem ser removidos do .env de produção.
#
# PRODUÇÃO:
#   Defina AWS_SECRET_NAME + AWS_REGION e deixe os campos [SECRET] em branco.
#   O servidor buscará automaticamente esses valores no AWS Secrets Manager.
#   Execute: python scripts/setup_aws_secret.py  (uma única vez por ambiente)
# =============================================================================

# =============================================================================
# AWS Secrets Manager — configure em produção para carregar os [SECRET] abaixo
# =============================================================================
# Nome do secret criado com scripts/setup_aws_secret.py
AWS_SECRET_NAME=
# Região onde o secret foi criado (padrão: us-east-1)
AWS_REGION=us-east-1

# =============================================================================
# [SECRET] Banco de dados
# Em produção: vai para o AWS Secrets Manager (chave DATABASE_URL)
# =============================================================================
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/bolao_copa

# =============================================================================
# [SECRET] JWT
# Em produção: vai para o AWS Secrets Manager (chave JWT_SECRET)
# Gere um segredo forte: openssl rand -hex 32
# =============================================================================
JWT_SECRET=CHANGE_ME

# Campos de JWT não-sensíveis (ficam no .env / env vars mesmo em produção)
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_COOKIE_NAME=bolao_refresh_token
# Em produção com HTTPS: defina como true
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAMESITE=strict
JWT_REFRESH_COOKIE_PATH=/auth

# =============================================================================
# Rate limit (por janela em segundos)
# =============================================================================
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_REFRESH_REQUESTS=20
RATE_LIMIT_AVATAR_PRE_IP_REQUESTS=10
RATE_LIMIT_AVATAR_PRE_TOKEN_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# Geral
# =============================================================================
# URL pública do front (usada em links de e-mail: convite e reset de senha)
PUBLIC_APP_URL=http://localhost:5173

# false em produção (desabilita /docs, aplica CSP restritiva, remove localhost do CORS)
DEBUG=false

# Origens CORS permitidas (separadas por vírgula).
# Em produção DEVE ser definido explicitamente para não incluir localhost:5173.
# Exemplo: CORS_ALLOWED_ORIGINS=https://bolao.suaempresa.com
CORS_ALLOWED_ORIGINS=

# =============================================================================
# [SECRET] Microsoft Graph / Outlook (envio de e-mail)
# Em produção: vai para o AWS Secrets Manager
# =============================================================================
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
OUTLOOK_SENDER=

# Campos não-sensíveis do Graph (ficam no .env mesmo em produção)
GRAPH_API_URL=https://graph.microsoft.com/v1.0
GRAPH_API_SCOPE=https://graph.microsoft.com/.default
EMAIL_MAX_ATTEMPTS=3
EMAIL_RETRY_BACKOFF_SECONDS=2.0
EMAIL_BULK_INTERVAL_SECONDS=1.0

# =============================================================================
# [SECRET] Redis — opcional, para rate limit distribuído (multi-réplica)
# Em produção: vai para o AWS Secrets Manager (chave REDIS_URL)
# Vazio = rate limit em memória local (ok para instância única)
# =============================================================================
REDIS_URL=
