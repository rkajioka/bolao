# PostgreSQL — ajuste usuário, senha, host e nome do banco
DATABASE_URL=postgresql+psycopg2://postgres:Palmeiras@1914@localhost:5432/bolao_copa

# JWT — use um segredo forte em produção (ex.: openssl rand -hex 32)
JWT_SECRET=altere-este-segredo-em-producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# URL pública do front (links em e-mails: convite e reset de senha)
PUBLIC_APP_URL=http://localhost:5173
