# PostgreSQL — ajuste usuário, senha, host e nome do banco
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bolao_copa

# JWT — use um segredo forte em produção (ex.: openssl rand -hex 32)
JWT_SECRET=altere-este-segredo-em-producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_COOKIE_NAME=bolao_refresh_token
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAMESITE=lax
JWT_REFRESH_COOKIE_PATH=/auth

# Rate limit (por janela em segundos)
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_REFRESH_REQUESTS=20
RATE_LIMIT_AVATAR_PRE_IP_REQUESTS=10
RATE_LIMIT_AVATAR_PRE_TOKEN_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# Redis opcional para rate limit distribuído (vazio = memória local)
REDIS_URL=

# URL pública do front (links em e-mails: convite e reset de senha)
PUBLIC_APP_URL=http://localhost:5173

# false em produção (desabilita /docs e aplica CSP restritiva na API)
DEBUG=false

# Origens CORS adicionais (vírgula); vazio = PUBLIC_APP_URL + http://localhost:5173
CORS_ALLOWED_ORIGINS=

# Microsoft Graph / Outlook (envio de e-mail)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
OUTLOOK_SENDER=
GRAPH_API_URL=https://graph.microsoft.com/v1.0
GRAPH_API_SCOPE=https://graph.microsoft.com/.default
EMAIL_MAX_ATTEMPTS=3
EMAIL_RETRY_BACKOFF_SECONDS=2.0
EMAIL_BULK_INTERVAL_SECONDS=1.0
