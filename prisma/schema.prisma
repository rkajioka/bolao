generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MatchStage {
  GROUP
  R16
  QF
  SF
  F
  THIRD
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String?
  role         Role      @default(USER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  userTournamentPicks UserTournamentPick[]
  userMatchPicks      UserMatchPick[]
  auditLogs           AuditLog[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  groupLetter String?  @map("group_letter")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  matchesAsA          Match[]              @relation("TeamA")
  matchesAsB          Match[]              @relation("TeamB")
  matchesWon          Match[]              @relation("MatchWinner")
  players             Player[]
  championPicks       UserTournamentPick[] @relation("ChampionTeam")
  userMatchPickWinner UserMatchPick[]      @relation("WinnerTeam")
}

model Match {
  id           String      @id @default(cuid())
  stage        MatchStage
  groupLetter  String?     @map("group_letter")
  round        Int?
  teamAId      String      @map("team_a_id")
  teamBId      String      @map("team_b_id")
  kickoffAt    DateTime    @map("kickoff_at")
  scoreA       Int?
  scoreB       Int?
  status       MatchStatus @default(PENDING)
  winnerTeamId String?     @map("winner_team_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  teamA       Team        @relation("TeamA", fields: [teamAId], references: [id], onDelete: Restrict)
  teamB       Team        @relation("TeamB", fields: [teamBId], references: [id], onDelete: Restrict)
  winnerTeam  Team?       @relation("MatchWinner", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  userPicks   UserMatchPick[]
  matchGoals  MatchGoal[]
}

model Player {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  name      String
  nameNorm  String   @map("name_norm")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team       Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchGoals MatchGoal[]
}

model MatchGoal {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  playerId  String   @map("player_id")
  teamId    String   @map("team_id")
  minute    Int?
  createdAt DateTime @default(now()) @map("created_at")

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model UserTournamentPick {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  championTeamId String?  @map("champion_team_id")
  goldenBall     String?  @map("golden_ball")
  goldenBoot     String?  @map("golden_boot")
  goldenGlove    String?  @map("golden_glove")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  championTeam Team? @relation("ChampionTeam", fields: [championTeamId], references: [id], onDelete: SetNull)
}

model UserMatchPick {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  matchId       String    @map("match_id")
  scoreA        Int
  scoreB        Int
  lockedAt      DateTime? @map("locked_at")
  winnerTeamId  String?   @map("winner_team_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match       Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerTeam  Team?  @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)

  @@unique([userId, matchId])
}

model ScoringConfig {
  id        String   @id @default(cuid())
  exact     Int      @default(3)
  outcome   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
